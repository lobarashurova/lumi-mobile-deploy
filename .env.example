DATABASE_URI=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
JWT_SECRET=
DOCS_PASSWORD=

# Eskiz SMS (notify.eskiz.uz). Same account used by notification-service.
# SMS_EMAIL/SMS_PASSWORD: Eskiz "SMS gateway" credentials (Settings -> SMS gateway).
# SMS_FROM: Eskiz-approved sender nickname. "4546" is Eskiz's test nickname
#   and ONLY works with the literal test template "This is test from Eskiz".
#   For the bilingual OTP template to actually deliver, set this to the same
#   approved branded sender the notification-service uses (e.g. LUMIPASS).
# The OTP message template in auth.service.ts must also be pre-approved in
# Eskiz (my.eskiz.uz -> SMS -> My texts). It already matches the template
# approved for notification-service, so no moderation re-submission is needed.
SMS_URL=https://notify.eskiz.uz
SMS_EMAIL=
SMS_PASSWORD=
SMS_FROM=
SMS_CALLBACK_URL=

PAYCOM_USERNAME_ID=Paycom
PAYCOM_MERCHANT_ID=
PAYCOM_API_KEY=
PAYCOM_TEST_API_KEY=
PAYCOM_CHECKOUT_URL=https://checkout.paycom.uz
PAYCOM_CHECKOUT_REDIRECT_URL=

# Admin panel access — set a strong random string, share with VITE_MOBILE_ADMIN_KEY in adminka frontend
ADMIN_API_KEY=
